# ==========================================
# 🚀 Environment Configuration Template
# ==========================================
# This file contains all environment variables required for the project.
# Copy this file to .env and adjust the values as needed.
#
# cp .env.example .env
#

# ------------------------------------------
# 🌐 General Application
# ------------------------------------------
NODE_ENV=development
# ------------------------------------------
# 🏗️ Local Network Contract Ports
# ------------------------------------------
# Single source of truth for ports to avoid collisions
PORTAL_WEB_PORT=4200
EDGE_PORTAL_PORT=3000
IDENTITY_HTTP_PORT=3001
IDENTITY_GRPC_PORT=50051

# Targets
PORTAL_EDGE_PROXY_TARGET=http://localhost:3000
IDENTITY_SERVICE_URL=http://localhost:3001
IDENTITY_GRPC_URL=localhost:50051
BILLING_GRPC_URL=localhost:50052
INVENTORY_GRPC_URL=localhost:50053
CATALOG_GRPC_URL=localhost:50051

# Electron Development Mode (Set to 1 for dev, 0 for prod)
ELECTRON_IS_DEV=1

# ------------------------------------------
# 🗄️ Database (PostgreSQL / TimescaleDB)
# ------------------------------------------
# Connection details for the main database
# Default values match the docker-compose.yml configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=virtex
DB_PASSWORD=password
DB_NAME=virtex_erp

# Use 'true' if connecting to a cloud DB with SSL (e.g., AWS RDS)
DB_SSL_ENABLED=false

# Read replica host (defaults to main host in dev)
DB_REPLICA_HOST=localhost

# Full Connection String (Often used by Prisma or Docker containers)
POSTGRES_URL=postgres://virtex:password@localhost:5432/virtex_erp

# ------------------------------------------
# 🧠 Redis (Cache & Pub/Sub)
# ------------------------------------------
# Used for caching, session storage, and inter-service communication
REDIS_URL=redis://localhost:6379

# ------------------------------------------
# 🔒 Security & Authentication
# ------------------------------------------
# CRITICAL: Secret used for HMAC signatures (Gateway <-> Plugin Host)
# Must be a strong, random string in production.
# Required by apps/virtex-api-gateway/src/main.ts
virtex_HMAC_SECRET=secret

# JWT Secret for signing tokens (if applicable)
JWT_SECRET=jwtsecret
JWT_EXPIRATION=3600s
SESSION_SECRET=virtex-dev-secret-session

# ------------------------------------------
# 📡 Telemetry (OpenTelemetry)
# ------------------------------------------
# Endpoint for OTLP exporter (e.g., Jaeger or OTEL Collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# Service name identifier (usually overridden per service, but good default)
SERVICE_NAME=virtex-service
# Tenant mode (SHARED or ISOLATED)
TENANT_MODE=SHARED
# Deployment region
AWS_REGION=us-east-1

# ------------------------------------------
# 💳 Payment Gateway (Stripe)
# ------------------------------------------
# Stripe API Keys (Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
# Stripe Webhook Secret (Dashboard > Developers > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ------------------------------------------
# 🧾 Billing & Fiscal (Finkok PAC)
# ------------------------------------------
# Credentials for the PAC provider (Finkok)
# Defaults point to the Demo environment for testing
FINKOK_USERNAME=usuario_demo
FINKOK_PASSWORD=password_demo
FINKOK_URL=https://demo-facturacion.finkok.com/servicios/soap/stamp

# ------------------------------------------
# 🧩 Plugin Host & Security Scanning
# ------------------------------------------
# SonarQube / SonarCloud URL for static analysis of plugins
SONAR_HOST_URL=http://localhost:9000
# Token for SonarQube (Required for analysis)
SONAR_TOKEN=your-sonar-token-here

# Snyk API for dependency vulnerability scanning
SNYK_API_URL=https://api.snyk.io/v1
# Token for Snyk (Required for vulnerability scanning)
SNYK_TOKEN=your-snyk-token-here

# ------------------------------------------
# 🖥️ Frontend & E2E Testing
# ------------------------------------------
# Base URL for E2E tests (Playwright/Cypress)
BASE_URL=http://localhost:4200

# ------------------------------------------
# 🐳 Docker Compose Secrets
# ------------------------------------------
POSTGRES_USER=virtex
POSTGRES_PASSWORD=password
POSTGRES_DB=virtex_core
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=password

# ------------------------------------------
# 🌐 Frontend (Public URL)
# ------------------------------------------
FRONTEND_URL=http://localhost:4200
CORS_ORIGIN=http://localhost:4200
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=user
SMTP_PASSWORD=pass
SMTP_FROM=noreply@example.com
EVIDENCE_SIGNING_SECRET=secret
AUDIT_HMAC_SECRET=secret
TENANT_ROUTING_HMAC_SECRET=secret
RECAPTCHA_SECRET_KEY=secret
