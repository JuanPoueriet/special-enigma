{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "jest.preset.js": ["{workspaceRoot}/jest.preset.js"],
    "production": [
      "default",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/eslint.config.mjs",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/jest.config.[jt]s",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/test-setup.[jt]s"
    ],
    "sharedGlobals": []
  },
  "plugins": [
    {
      "plugin": "@nx/js",
      "options": {
        "buildTargetName": "build"
      }
    },
    {
      "plugin": "@nx/webpack/plugin",
      "options": {
        "buildTargetName": "build",
        "serveTargetName": "serve",
        "previewTargetName": "preview",
        "buildDepsTargetName": "build-deps",
        "watchDepsTargetName": "watch-deps",
        "serveStaticTargetName": "serve-static"
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/jest/plugin",
      "options": {
        "targetName": "test"
      },
      "exclude": [
        "apps/service-identity-e2e/**/*",
        "apps/worker-scheduler-e2e/**/*",
        "apps/service-fiscal-e2e/**/*",
        "apps/service-catalog-e2e/**/*",
        "apps/worker-notification-e2e/**/*",
        "apps/service-billing-e2e/**/*",
        "apps/service-accounting-e2e/**/*",
        "apps/service-payroll-e2e/**/*",
        "apps/service-projects-e2e/**/*",
        "apps/service-manufacturing-e2e/**/*",
        "apps/service-treasury-e2e/**/*",
        "apps/service-purchasing-e2e/**/*",
        "apps/service-bi-e2e/**/*",
        "apps/service-admin-e2e/**/*",
        "apps/service-fixed-assets-e2e/**/*",
        "apps/edge/portal/e2e/**/*",
        "apps/edge/pos/e2e/**/*",
        "apps/edge/wms/e2e/**/*",
        "apps/edge/shopfloor/e2e/**/*",
        "apps/edge/support/e2e/**/*",
        "apps/edge/cms/e2e/**/*",
        "apps/edge/site/app-public-e2e/**/*",
        "apps/edge/storefront/e2e/**/*",
        "apps/service/authn-credential/app-e2e/**/*",
        "apps/service/risk-adaptive-auth/app-e2e/**/*",
        "apps/service/identity-profile/app-e2e/**/*",
        "apps/service/provisioning-federation/app-e2e/**/*",
        "apps/service/token/app-e2e/**/*",
        "apps/service/session/app-e2e/**/*",
        "apps/service/authorization-policy/app-e2e/**/*",
        "apps/service/identity-audit-ledger/app-e2e/**/*",
        "apps/service/api-access-gateway/app-e2e/**/*"
      ]
    },
    {
      "plugin": "@nx/playwright/plugin",
      "options": {
        "targetName": "e2e"
      }
    }
  ],
  "targetDefaults": {
    "@angular/build:application": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "@nx/esbuild:esbuild": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "@nx/js:tsc": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "@nx/vitest:test": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "lint": {
      "cache": true,
      "inputs": [
        "default",
        "{workspaceRoot}/eslint.config.mjs",
        "{workspaceRoot}/tools/validate-architecture-boundaries.mjs"
      ]
    }
  },
  "generators": {
    "@nx/angular:application": {
      "e2eTestRunner": "playwright",
      "linter": "eslint",
      "style": "scss",
      "unitTestRunner": "jest"
    },
    "@nx/angular:library": {
      "linter": "eslint",
      "unitTestRunner": "vitest-analog"
    },
    "@nx/angular:component": {
      "style": "css"
    }
  },
  "defaultProject": "web-portal-app"
}
