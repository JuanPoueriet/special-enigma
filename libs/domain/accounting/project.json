{
  "name": "domain-accounting",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "interface",
  "sourceRoot": "libs/domain/accounting",
  "tags": [
    "scope:accounting",
    "type:domain",
    "platform:agnostic",
    "criticality:high",
    "compliance:none",
    "tenant-mode:none",
    "region:global"
  ],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/domain/accounting/**/*.ts"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run-many --target=test --projects=tag:scope:accounting"
        ]
      }
    }
  }
}
