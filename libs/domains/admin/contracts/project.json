{
  "name": "contracts-admin-contracts",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/domains/admin/contracts/src",
  "projectType": "library",
  "prefix": "virteex",
  "tags": [
    "scope:admin",
    "type:contract",
    "platform:agnostic",
    "criticality:medium"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/domains/admin/contracts",
        "main": "libs/domains/admin/contracts/src/index.ts",
        "tsConfig": "libs/domains/admin/contracts/tsconfig.lib.json",
        "assets": [
          "libs/domains/admin/contracts/*.md"
        ],
        "rootDir": "."
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../../../coverage/libs/domains/admin/contracts"
      }
    }
  }
}
