        "packageJson": "libs/domains/accounting/presentation/package.json",
        "main": "libs/domains/accounting/presentation/src/index.ts",
        "assets": [
          "libs/domains/accounting/presentation/*.md"
        ]
      }
    }
  },
  "prefix": "virteex"
