{
  "name": "edge-ops-app",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/edge/ops/app/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/edge/ops/app",
        "main": "apps/edge/ops/app/src/main.ts",
        "tsConfig": "apps/edge/ops/app/tsconfig.app.json",
        "compiler": "tsc",
        "target": "node",
        "webpackConfig": "apps/edge/ops/app/webpack.config.js"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        },
        "development": {}
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nx build edge-ops-app --configuration=development && node dist/apps/edge/ops/app/main.js"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/edge/ops/app/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": [
    "scope:edge",
    "scope:ops",
    "type:bff",
    "platform:node",
    "criticality:medium"
  ]
}
