{
  "name": "frontend-portal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "virteex",
  "sourceRoot": "apps/frontend/portal/src",
  "tags": [
    "platform:web"
  ],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/frontend/portal",
        "browser": "apps/frontend/portal/src/main.ts",
        "tsConfig": "apps/frontend/portal/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/frontend/portal/public"
          }
        ],
        "styles": [
          "apps/frontend/portal/src/styles.scss"
        ],
        "stylePreprocessorOptions": {
          "includePaths": [
            "libs/shared/ui/src/lib/styles"
          ]
        }
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/frontend/portal/src/environments/environment.ts",
              "with": "apps/frontend/portal/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "10kb",
              "maximumError": "20kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "frontend-portal:build:production"
        },
        "development": {
          "buildTarget": "frontend-portal:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "apps/frontend/portal/proxy.conf.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/frontend/portal/jest.config.cts",
        "tsConfig": "apps/frontend/portal/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "frontend-portal:build",
        "port": 4200,
        "staticFilePath": "dist/apps/frontend/portal/browser",
        "spa": true
      }
    }
  }
}