{
  "name": "frontend-desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/frontend/desktop/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx-electron:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/frontend/desktop",
        "main": "apps/frontend/desktop/src/main.ts",
        "tsConfig": "apps/frontend/desktop/tsconfig.app.json",
        "assets": [
          "apps/frontend/desktop/src/assets"
        ]
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false,
          "fileReplacements": [
            {
              "replace": "apps/frontend/desktop/src/environments/environment.ts",
              "with": "apps/frontend/desktop/src/environments/environment.prod.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "executor": "nx-electron:execute",
      "options": {
        "buildTarget": "frontend-desktop:build"
      }
    },
    "package": {
      "executor": "nx-electron:package",
      "options": {
        "name": "frontend-desktop",
        "frontendProject": "frontend-portal",
        "sourcePath": "dist/apps",
        "outputPath": "dist/packages",
        "prepackageOnly": true
      }
    },
    "make": {
      "executor": "nx-electron:make",
      "options": {
        "name": "frontend-desktop",
        "frontendProject": "frontend-portal",
        "sourcePath": "dist/apps",
        "outputPath": "dist/executables"
      }
    },
    "lint": {
      "command": "eslint apps/frontend/desktop/**/*.ts"
    }
  },
  "prefix": "virteex"
}